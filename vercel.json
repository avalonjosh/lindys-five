{
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/weekly-roundup",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/cron/news-scan",
      "schedule": "0 10 * * 2,4,6"
    },
    {
      "path": "/api/cron/game-recap",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/set-recap",
      "schedule": "0 11 * * 0"
    },
    {
      "path": "/api/cron/bills-news-scan",
      "schedule": "0 10 * * 1,3,5"
    },
    {
      "path": "/api/cron/bills-weekly-roundup",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/cron/bills-game-recap",
      "schedule": "0 5,10 * * 1"
    }
  ]
}
